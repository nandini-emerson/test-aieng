
# ============================================================
# .env.example — Configuration for College Course Enrollment Assistant
# Copy this file to .env and fill in the required values.
# Variables marked as (pre-configured) are already set.
# ============================================================

# ══════════════════════════════════════════════════════════
# Agent Identity (PRELOADED)
# ══════════════════════════════════════════════════════════
AGENT_NAME=College Course Enrollment Assistant            # Agent name (pre-configured)
AGENT_ID=313c15a0-18c0-4128-93ad-b9ca603a6c17             # Agent unique identifier (pre-configured)
PROJECT_NAME=19test                                       # Project name (pre-configured)
PROJECT_ID=6675d4e6-9f20-4270-8609-43760b6667ff           # Project unique identifier (pre-configured)
USE_KEY_VAULT=false                                       # Enable Azure Key Vault integration (set to true for production) (pre-configured)
OBS_AZURE_SQL_TRUST_SERVER_CERTIFICATE=yes

# ══════════════════════════════════════════════════════════
# General Configuration
# ══════════════════════════════════════════════════════════
ENVIRONMENT=                          # Deployment environment (e.g., development, production)
SERVICE_NAME=                         # Service name for observability and logging
SERVICE_VERSION=                      # Service version number
APP_NAME=                             # Application name used by tracing/resource attributes
APP_VERSION=                          # Application version used by tracing/resource attributes
VERSION=                              # Software version (semantic version)
VALIDATION_CONFIG_PATH=               # Path to validation configuration (local file path used by validators)
OTEL_DATABASE_EXPORT=                 # Toggle OpenTelemetry DB exporter (true/false)

# ══════════════════════════════════════════════════════════
# Azure Key Vault
# ══════════════════════════════════════════════════════════
KEY_VAULT_URI=                         # Azure Key Vault URI (e.g., https://your-vault.vault.azure.net/)
AZURE_USE_DEFAULT_CREDENTIAL=          # Use DefaultAzureCredential for Key Vault (true for managed identity, false for service principal)

# ══════════════════════════════════════════════════════════
# Azure Authentication
# ══════════════════════════════════════════════════════════
AZURE_TENANT_ID=                       # Azure AD tenant ID for authentication
AZURE_CLIENT_ID=                       # Azure AD client/application ID
AZURE_CLIENT_SECRET=                   # Azure AD client secret

# ══════════════════════════════════════════════════════════
# LLM Configuration
# ══════════════════════════════════════════════════════════
MODEL_PROVIDER=openai
LLM_MODEL=                             # LLM model name (e.g., gpt-4.1, claude-3-opus)
LLM_TEMPERATURE=                       # Model temperature (0.0-2.0, controls randomness)
LLM_MAX_TOKENS=                        # Maximum tokens in model response
LLM_MODELS=                            # JSON list of model metadata for observability cost lookup
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=     # Azure OpenAI embedding deployment name used for embeddings

# ══════════════════════════════════════════════════════════
# API Keys / Secrets
# ══════════════════════════════════════════════════════════
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=                     # Anthropic API key (if using Anthropic provider)
GOOGLE_API_KEY=                        # Google API key (if using Google provider)
AZURE_CONTENT_SAFETY_KEY=
OBS_AZURE_SQL_PASSWORD=
# Note: AZURE_CLIENT_SECRET is listed under Azure Authentication above (service principal secret)

# ══════════════════════════════════════════════════════════
# Service Endpoints
# ══════════════════════════════════════════════════════════
AZURE_OPENAI_ENDPOINT=https://kb-openai-01.openai.azure.com/openai/deployments/text-embedding-ada-002/embeddings?api-version=2023-05-15
AZURE_SEARCH_ENDPOINT=                  # Azure AI Search endpoint URL (for knowledge base / RAG agents)
AZURE_CONTENT_SAFETY_ENDPOINT=https://az-ai-guardrails.cognitiveservices.azure.com/
# (KEY_VAULT_URI is listed in Azure Key Vault section)

# ══════════════════════════════════════════════════════════
# Observability
# ══════════════════════════════════════════════════════════
OBS_DATABASE_TYPE=azure_sql
OBS_AZURE_SQL_SERVER=masgenaisqlserver.database.windows.net
OBS_AZURE_SQL_DATABASE=masgenaisql
OBS_AZURE_SQL_PORT=1433
OBS_AZURE_SQL_USERNAME=saadmin
# OBS_AZURE_SQL_PASSWORD included in API Keys / Secrets (sensitive)
OBS_AZURE_SQL_SCHEMA=dbo
OBS_AZURE_SQL_TRUST_SERVER_CERTIFICATE=yes
# Note: Observability/telemetry toggles
OTEL_DATABASE_EXPORT=                   # Enable exporting traces to observability DB (true/false)

# ══════════════════════════════════════════════════════════
# Agent-Specific
# ══════════════════════════════════════════════════════════
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=api-knowledge
RAG_TOP_K=                              # Number of retrieval results to return (top-k) for RAG
SELECTED_DOCUMENT_TITLES=               # Comma-separated list of document titles to restrict retrieval (optional)
CONTENT_SAFETY_ENABLED=                 # Toggle content safety checks (true/false)
CONTENT_SAFETY_SEVERITY_THRESHOLD=      # Severity threshold for content safety (integer)
CONTENT_SAFETY_CHECK_INPUT=             # Whether to run content safety on input (true/false)
CONTENT_SAFETY_CHECK_OUTPUT=            # Whether to run content safety on output (true/false)
VALIDATION_CONFIG_PATH=                 # Path to validation_config.json (agent-specific file path)
# Additional observability model-cost lookup (JSON array expected)
LLM_MODELS=                             # JSON array describing model token cost entries used by observability

# ============================================================
# Notes:
# - Do NOT commit real secrets to version control. Copy this file to `.env`
#   and fill in the required values locally or in your deployment pipeline.
# - Variables marked as (pre-configured) are set by the agent bundle and do
#   not need to be changed for local testing.
# - Set USE_KEY_VAULT=true and KEY_VAULT_URI to enable Azure Key Vault-based secret
#   fetching in production (requires AZURE_* authentication variables or managed identity).
# ============================================================
